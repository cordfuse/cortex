{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Edit(protocol/**)",
      "Write(protocol/**)",
      "Edit(templates/**)",
      "Write(templates/**)",
      "Edit(scripts/*.py)",
      "Write(scripts/*.py)",
      "Edit(version.txt)",
      "Write(version.txt)",
      "Edit(.cortex-version)",
      "Write(.cortex-version)",
      "Edit(LICENSE)",
      "Write(LICENSE)",
      "Edit(cortex-changelog.md)",
      "Write(cortex-changelog.md)",
      "Edit(ROADMAP.md)",
      "Write(ROADMAP.md)",
      "Edit(README.md)",
      "Write(README.md)",
      "Edit(README-SIMPLE.md)",
      "Write(README-SIMPLE.md)",
      "Edit(README-simple.md)",
      "Write(README-simple.md)",
      "Edit(VERBS.md)",
      "Write(VERBS.md)",
      "Edit(install.sh)",
      "Write(install.sh)",
      "Edit(install.ps1)",
      "Write(install.ps1)",
      "Edit(setup.sh)",
      "Write(setup.sh)",
      "Edit(setup.ps1)",
      "Write(setup.ps1)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)"
    ]
  }
}
